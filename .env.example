# ── Database ──────────────────────────────────────────────────────────────────
# Used by the `db` service to create the Postgres role/database, and read
# by `backend` to derive its DATABASE_URL.
POSTGRES_USER=securestats
POSTGRES_PASSWORD=changeme
POSTGRES_DB=securestats

# Full SQLAlchemy URL. Inside docker-compose, the host MUST be the
# service name `db` (Docker's embedded DNS resolves it). For host-mode
# development, use `localhost`.
#   compose : postgresql+psycopg://securestats:changeme@db:5432/securestats
#   host    : postgresql+psycopg://securestats:changeme@localhost:5432/securestats
DATABASE_URL=postgresql+psycopg://securestats:changeme@db:5432/securestats

# ── JWT ───────────────────────────────────────────────────────────────────────
# SECRET_KEY must be a long random string in production. Generate one with:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=replace-with-a-long-random-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ── Environment ───────────────────────────────────────────────────────────────
# `development` enables verbose logs / dev CORS. `production` tightens both.
ENVIRONMENT=development

# ── Frontend (build-time) ─────────────────────────────────────────────────────
# Baked into the SPA bundle by Vite. In docker-compose the SPA hits its
# own nginx at /api/v1, which proxies to the backend service.
VITE_API_URL=/api/v1
